{
	"name": "still",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"@types/bun": "^1.3.4",
			"better-auth": "1.6.9",
			"lucide-react": "^0.546.0",
			"next-themes": "^0.4.6",
			"sonner": "^2.0.5",
			"@tanstack/react-form": "^1.28.0",
			"@polar-sh/better-auth": "^1.8.3",
			"@types/react-dom": "^19.2.3",
			"@better-auth/expo": "1.6.9"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @still/db db:push",
		"db:studio": "turbo -F @still/db db:studio",
		"db:generate": "turbo -F @still/db db:generate",
		"db:migrate": "turbo -F @still/db db:migrate",
		"db:seed-journal": "turbo -F @still/db db:seed-journal",
		"db:baseline": "bun run ./packages/db/src/baseline-migrations.ts",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@still/env": "workspace:*",
		"agentation-mcp": "^1.2.0",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@still/config": "workspace:*",
		"@types/bun": "catalog:",
		"lefthook": "^2.0.13",
		"turbo": "^2.8.12",
		"typescript": "^6"
	},
	"packageManager": "bun@1.3.9",
	"overrides": {
		"@types/react": "19.2.10"
	}
}
