{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", ".output/**"],
			"env": [
				"API_REWRITE_ORIGIN",
				"BETTER_AUTH_SECRET",
				"BETTER_AUTH_URL",
				"POLAR_ACCESS_TOKEN",
				"POLAR_SUCCESS_URL",
				"POLAR_WEBHOOK_SECRET",
				"POLAR_SERVER",
				"POLAR_PRODUCT_ATTUNED_MONTHLY",
				"POLAR_PRODUCT_ATTUNED_YEARLY",
				"POLAR_PRODUCT_IMMERSED_MONTHLY",
				"POLAR_PRODUCT_IMMERSED_YEARLY",
				"POLAR_DISCOUNT_REFERRAL10",
				"CORS_ORIGIN",
				"DATABASE_URL",
				"BLOB_READ_WRITE_TOKEN",
				"BLOB_STORE_ACCESS",
				"TMDB_API_KEY"
			]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false,
			"persistent": true
		},
		"db:seed-journal": {
			"cache": false
		},
		"db:baseline": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		}
	}
}
