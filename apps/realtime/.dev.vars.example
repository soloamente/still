# Local secrets for `wrangler dev` in apps/realtime.
# Copy to `.dev.vars` (gitignored) and fill with real values — never commit secrets here.
#
#   cp .dev.vars.example .dev.vars

# Must match apps/server REALTIME_* secrets (connect tokens + internal publish API).
REALTIME_JWT_SECRET=replace-with-openssl-rand-base64-32
REALTIME_INTERNAL_SECRET=replace-with-openssl-rand-base64-32

# Optional local overrides (wrangler.jsonc vars are used when unset).
# SERVER_ORIGIN=http://localhost:3000
# ALLOWED_ORIGINS=
