{
	"name": "server",
	"type": "module",
	"main": "src/local.ts",
	"exports": {
		".": "./src/local.ts",
		"./app": "./src/server/app.ts"
	},
	"scripts": {
		"build": "tsdown",
		"build:vercel": "bun build ./src/server/app.ts --outfile ./src/index.mjs --target node --minify",
		"cf:dev": "wrangler dev",
		"cf:dry-run": "wrangler deploy --dry-run --outdir .wrangler-dryrun",
		"check-types": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/local.ts --outfile server",
		"dev": "bun run --hot src/local.ts",
		"palette:backfill": "bun run ./scripts/backfill-movie-palette.ts",
		"start": "bun run dist/local.mjs"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/eden": "^1.4.9",
		"@sinclair/typebox": "^0.34.49",
		"@still/auth": "workspace:*",
		"@still/db": "workspace:*",
		"@still/env": "workspace:*",
		"@polar-sh/sdk": "^0.42.2",
		"@still/realtime": "workspace:*",
		"@upstash/redis": "^1.34.0",
		"@vercel/blob": "^2.4.0",
		"aws4fetch": "^1.0.20",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.45.2",
		"elysia": "^1.4.28",
		"fflate": "^0.8.3",
		"node-vibrant": "^4.0.3",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250617.0",
		"@still/config": "workspace:*",
		"@types/bun": "catalog:",
		"tsdown": "^0.21.9",
		"typescript": "^6",
		"wrangler": "^4.40.0"
	}
}
